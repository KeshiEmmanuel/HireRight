---
import Hero from "../components/Hero.astro";
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
import { Font } from "astro:assets";
import EmployersSection from "../components/EmployersSection.astro";
import JobSeekersSection from "../components/JobSeekersSection.astro";
import Footer from "../components/Footer.astro";
import TrustBar from "../components/TrustBar.astro";
import JobOpportunites from "../components/JobOpportunites.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>
      Goodwin Recruiting - the Best Recruitment Firm - Recoginized by Forbes
    </title>
    <Font cssVariable="--font-tight" preload />
    <Font cssVariable="--font-funnel" preload />
  </head>

  <body>
    <main class="font-tight">
      <Navbar />
      <Hero />
      <TrustBar />
      <EmployersSection />
      <JobSeekersSection />
      <JobOpportunites />
      <Footer />
    </main>
  </body>
</html>
